    {
      "name": "Auth",
      "item": [
        {
          "name": "Register Admin",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"full_name\": \"Postman Admin\",\n  \"email\": \"postman.admin@logipulse.demo\",\n  \"password\": \"Test1234\",\n  \"role\": \"admin\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/auth/register",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "auth", "register"]
            },
            "description": "Creates a fresh admin account for testing the register endpoint. The seeded demo admin already exists, so this uses a different email to avoid a 400 (email already registered)."
          },
          "response": []
        },
        {
          "name": "Register Driver",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"full_name\": \"Postman Driver\",\n  \"email\": \"postman.driver@logipulse.demo\",\n  \"password\": \"Test1234\",\n  \"role\": \"driver\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/auth/register",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "auth", "register"]
            },
            "description": "Creates a fresh driver account for testing the register endpoint."
          },
          "response": []
        },
        {
          "name": "Login Admin",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"Login successful\", function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "const data = pm.response.json();",
                  "if (data.access_token) {",
                  "    pm.environment.set(\"admin_token\", data.access_token);",
                  "    console.log(\"admin_token saved\");",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{admin_email}}\",\n  \"password\": \"{{admin_password}}\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/auth/login",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "auth", "login"]
            },
            "description": "Logs in with the seeded demo admin account and saves the token to admin_token automatically. Run this before any other admin request."
          },
          "response": []
        },
        {
          "name": "Login Driver",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"Login successful\", function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "const data = pm.response.json();",
                  "if (data.access_token) {",
                  "    pm.environment.set(\"driver_token\", data.access_token);",
                  "    console.log(\"driver_token saved\");",
                  "",
                  "    // Save this driver's own id too, decoded straight from the token.",
                  "    // This keeps Create Route / Assign Driver pointed at the SAME driver",
                  "    // that driver_token belongs to, even if other drivers exist in the database",
                  "    // and 'List Drivers' (Users folder) later saves a different id into driver_id.",
                  "    const payload = JSON.parse(atob(data.access_token.split('.')[1]));",
                  "    if (payload.sub) {",
                  "        pm.environment.set(\"driver_id\", payload.sub);",
                  "        console.log(\"driver_id saved from token: \" + payload.sub);",
                  "    }",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{driver_email}}\",\n  \"password\": \"{{driver_password}}\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/auth/login",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "auth", "login"]
            },
            "description": "Logs in with the seeded demo driver1 account, saves the token to driver_token, and saves driver1's own id to driver_id (decoded from the token) so Create Route / Assign Driver stay in sync with driver_token's owner. Run this before any other driver request."
          },
          "response": []
        }
      ]
    },
    {
